  "constitutionalGates": {
    "description": "10 immutable gates per ADR-2606272030. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every published record",
      "G2": "kotoba-datomic attestation lineage (provenance receipts) on every record",
      "G3": "PROVENANCE-OR-SILENCE — no point without ≥3 independent recorded comps AND ≥2 independent authorities AND a fresh anchor; else MRV band / insufficient-evidence",
      "G4": "DERIVED/AGGREGATE license discipline — ToS-restricted inputs publish derived-only; per-parcel-barred jurisdictions publish aggregate-only; raw republication of restricted data PROHIBITED",
