  "@type": "ActorManifest",
  "id": "did:web:kenchi.etzhayyim.com",
  "name": "kenchi",
  "displayName": "検地 — Worldwide Real-Estate Valuation (External-Market Transparency)",
  "displayNameJa": "検地",
  "displayNameEn": "Kenchi",
  "description": "Public-good worldwide real-estate valuation + transparency substrate. Fuses many DISAGREEING independent authorities (recorded sales, public assessments, indices, and open-crawl listing prices) into provenance-stamped, uncertainty-quantified EXTERNAL-MARKET valuations and aggregate region reports. PROVENANCE-OR-SILENCE (G3): never a point without ≥3 independent recorded comps AND ≥2 independent authorities AND a fresh anchor — below threshold it publishes a wide band or insufficient-evidence, never false precision. DERIVED/AGGREGATE license discipline (G4): ToS-restricted inputs publish derived-only; per-parcel-barred jurisdictions publish aggregate-only. INALIENABLE-LAND EXCLUSION (G5): kenchi NEVER assigns a market price to the etzhayyim Land Trust's inalienable holdings (ADR-2605192245 — inalienable land has no market price); that non-market STOCK is toritate.commonsAssetAccess. NO-PII (G6): a parcel is a place, not a person. Murakumo-only inference (G7). Open-source + open-data-first (G8). 6 cells / 4 Lexicons / 10 gates / 10 non-goals.",
  "descriptionJa": "公共財としての全世界・不動産価値+透明性 substrate。互いに食い違う複数の独立 authority（記録済み取引・公的評価・指数・オープンクロールの売出し価格）を融合し、来歴付き・不確実性付きの EXTERNAL-MARKET 評価と地域集約レポートとして公開。PROVENANCE-OR-SILENCE (G3): 独立 comps ≥3 かつ 独立 authority ≥2 かつ 新鮮なアンカーが揃わない限り点推定を出さない（不足時は広い帯か insufficient-evidence、偽の精度を出さない）。DERIVED/AGGREGATE 規律 (G4): ToS 制限入力は derived-only、per-parcel 公開不可地域は aggregate-only。INALIENABLE-LAND EXCLUSION (G5): etzhayyim Land Trust の譲渡不能保有地に市場価格を一切付けない（ADR-2605192245 — 譲渡不能の土地に市場価格は無い）。その非市場 STOCK は toritate.commonsAssetAccess の領分。NO-PII (G6): parcel は場所であり人ではない。Murakumo-only 推論 (G7)。オープンソース+オープンデータ優先 (G8)。6 cells / 4 Lexicons / 10 gates / 10 non-goals。",
  "adr": {
    "master": "etzhayyim:adr:2606272030",
    "parent": "etzhayyim:adr:2605192245",
    "r0": "etzhayyim:adr:2606272030",
    "r1": "reserved",
    "r2": "reserved",
    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "implementation": "git@github.com:com-junkawasaki/kenchi-actor (langgraph-clj engine — fusion/governor/parcel StateGraph + ingest adapters + Common Crawl + flywheel). This actor cell is the published etzhayyim identity + charter + lexicons + source registry over that engine.",
  "crossActorBoundary": [
    "did:web:toritate.etzhayyim.com (EXTERNAL-MARKET context boundary, 1-way: kenchi MAY provide external comparables for Land Registry acquisition due-diligence read, but NEVER values toritate's inalienable Land Trust holdings; the internal commons-asset value — non-market imputed STOCK, ACCESS-NOT-TITLE — is toritate.commons_asset_value per ADR-2605301020 §2 + ADR-2605192245)",
    "Land Registry on-chain contract (acquisition read — external market comparables only, advisory transparency, NEVER a valuation of acquired-then-inalienable trust land)"
  ],
  "lexiconReadAccess": {
    "com.etzhayyim.corp.leiReference": "READ-ONLY GLEIF LEI for resolving the AUTHORITY behind a data source (anti-spoofing of provenance). CC0 1.0.",
    "com.etzhayyim.gov.dataset.budgetRecord": "READ-ONLY per-jurisdiction open gov datasets as additional open valuation/assessment authorities (G8 open-data-first)."
  },
  "form": "公共財 external-market valuation + transparency substrate (NOT a brokerage / AVM vendor / appraisal firm / 法人格)",
  "constitutionalDiscipline": {
    "provenanceOrSilence": "G3 — never publish a point without ≥3 independent recorded comps AND ≥2 independent authorities AND a fresh anchor; below threshold → MRV band / insufficient-evidence",
    "derivedAggregateLicense": "G4 — ToS-restricted inputs publish derived-only; per-parcel-barred jurisdictions publish aggregate-only (regionReport); raw republication of restricted data PROHIBITED",
    "inalienableLandExclusion": "G5 — kenchi NEVER assigns a market price to etzhayyim Land Trust inalienable holdings (ADR-2605192245 / 2605192330); external market only; internal commons-asset value is toritate.commonsAssetAccess (non-market STOCK)",
    "noPii": "G6 — a parcel is a place, not a person; no owner linkage, no individual wealth surveillance",
    "murakumoOnlyInference": "G7 — Murakumo-only inference per ADR-2605215000; ToS-restricted inputs never leave the mesh; only derived records published",
    "openSourceOpenData": "G8 — no closed AVM / closed tooling; sources must be open data or used derived-only"
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "External-market multi-authority valuation fusion + provenance-gated publication + aggregate region transparency reports",
    "exclusions": [
      "Land Trust / inalienable-land market valuation (ADR-2605192245 — has no market price)",
      "price prediction / speculation / trading signals",
      "individual property or owner surveillance (no PII / no wealth maps)",
      "closed / proprietary AVM",
      "raw republication of ToS-restricted portal data (derived-only only)",
      "financial / investment / valuation advice to individuals (UPL-equivalent for appraisal)",
      "per-person wealth assessment (that boundary is toritate basicHighIncome, aggregate-only)",
      "single-source oracle (no trusting one provider)",
      "real-estate brokerage / listing marketplace",
      "closed-source tooling"
    ]
  },
  "cells": [
    { "name": "kenchi_ingest", "module": "kenchi.ingest + kenchi.commoncrawl", "murakumoNode": "naphtali", "phase": "continuous", "io": "multi-authority fetch (sales/assessment/index) + open-crawl listings → stamped Observations" },
    { "name": "kenchi_fusion", "module": "kenchi.fusion", "murakumoNode": "naphtali", "phase": "continuous", "io": "robust price-comp ensemble (weighted median + CI); indices corroborate, never vote the £ point" },
    { "name": "kenchi_provenance_governor", "module": "kenchi.governor", "murakumoNode": "naphtali", "phase": "continuous", "io": "G3 gate: ≥3 comps + ≥2 authorities + fresh anchor; outlier reject; license clear (G4) → publish | MRV" },
    { "name": "kenchi_publish", "module": "kenchi.publish", "murakumoNode": "judah", "phase": "continuous", "io": "cleared record → PDS/Aozora + kqe-assert! to Datom log (mesh on-http/on-tick)" },
    { "name": "kenchi_region_aggregate", "module": "kenchi.fusion/region-aggregate", "murakumoNode": "judah", "phase": "continuous", "io": "H3/region median+quartiles → regionReport (AGGREGATE-ONLY, G4)" },
    { "name": "kenchi_flywheel", "module": "kenchi.flywheel", "murakumoNode": "judah", "phase": "periodic", "io": "backtest fused estimate vs realized sales → recalibrate per-authority reliability" }
  ],
  "lexiconNamespaces": [
    "com.etzhayyim.kenchi.valuation",
    "com.etzhayyim.kenchi.regionReport",
    "com.etzhayyim.kenchi.provenanceAttestation",
